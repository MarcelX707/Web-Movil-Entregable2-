<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Modelo Relacional — Sistema de Trámites</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Syne:wght@700;800&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0b0e14;
    --surface: #111520;
    --border: #1e2535;
    --accent1: #4fffb0;
    --accent2: #4fc3ff;
    --accent3: #ff6b6b;
    --accent4: #ffc84a;
    --accent5: #c084fc;
    --text: #e2e8f0;
    --muted: #64748b;
    --pk: #4fffb0;
    --fk: #4fc3ff;
    --uk: #ffc84a;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'IBM Plex Mono', monospace;
    min-height: 100vh;
    overflow-x: auto;
  }

  header {
    padding: 2.5rem 3rem 1.5rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-end;
    gap: 2rem;
    flex-wrap: wrap;
  }

  header h1 {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.4rem, 3vw, 2.2rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  header h1 span { color: var(--accent1); }

  .subtitle {
    font-size: 0.72rem;
    color: var(--muted);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-bottom: 3px;
  }

  .legend {
    margin-left: auto;
    display: flex;
    gap: 1.4rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    font-size: 0.68rem;
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  .legend-dot {
    width: 10px; height: 10px;
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ─── Canvas ─── */
  .canvas {
    padding: 3rem;
    position: relative;
    min-width: 1200px;
  }

  svg.relations {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ─── Tables ─── */
  .grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(4, 260px);
    grid-template-rows: auto;
    gap: 2rem;
    /* Named areas match positions in the spec */
  }

  .table-card {
    border: 1px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    background: var(--surface);
    box-shadow: 0 0 0 0 transparent;
    transition: box-shadow 0.25s;
    position: relative;
  }

  .table-card:hover {
    box-shadow: 0 0 28px -4px color-mix(in srgb, var(--accent-color) 35%, transparent);
  }

  .table-header {
    background: color-mix(in srgb, var(--accent-color) 14%, var(--surface));
    border-bottom: 2px solid var(--accent-color);
    padding: 0.65rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .table-header h2 {
    font-family: 'IBM Plex Mono', monospace;
    font-weight: 600;
    font-size: 0.8rem;
    color: var(--accent-color);
    letter-spacing: 0.05em;
  }

  .table-icon {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--accent-color);
    box-shadow: 0 0 6px var(--accent-color);
  }

  .fields { list-style: none; }

  .field {
    display: grid;
    grid-template-columns: 18px 1fr auto;
    gap: 0.4rem;
    align-items: start;
    padding: 0.42rem 1rem;
    border-bottom: 1px solid color-mix(in srgb, var(--border) 60%, transparent);
    font-size: 0.7rem;
    line-height: 1.4;
  }

  .field:last-child { border-bottom: none; }

  .field-badge {
    font-size: 0.55rem;
    font-weight: 600;
    padding: 1px 3px;
    border-radius: 2px;
    letter-spacing: 0.04em;
    margin-top: 2px;
    text-align: center;
  }

  .badge-pk { background: color-mix(in srgb, var(--pk) 20%, transparent); color: var(--pk); border: 1px solid color-mix(in srgb, var(--pk) 40%, transparent); }
  .badge-fk { background: color-mix(in srgb, var(--fk) 20%, transparent); color: var(--fk); border: 1px solid color-mix(in srgb, var(--fk) 40%, transparent); }
  .badge-uk { background: color-mix(in srgb, var(--uk) 20%, transparent); color: var(--uk); border: 1px solid color-mix(in srgb, var(--uk) 40%, transparent); }

  .field-name { color: var(--text); }
  .field-type { color: var(--muted); font-size: 0.62rem; margin-top: 1px; }

  .field-desc {
    color: #3d5068;
    font-size: 0.6rem;
    text-align: right;
    line-height: 1.3;
    max-width: 110px;
    word-break: break-word;
  }

  /* ─── Section labels ─── */
  .section-label {
    font-family: 'Syne', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 0.6rem;
    margin-top: 0.5rem;
  }

  /* ─── Relationship lines (SVG) ─── */
  .rel-line { stroke-width: 1.5; fill: none; stroke-dasharray: 5 3; opacity: 0.6; }
  .rel-line.solid { stroke-dasharray: none; }

  /* ─── Module groups ─── */
  .module-group {
    grid-column: span 4;
    display: contents;
  }

  /* ─── Positions via inline style ─── */
</style>
</head>
<body>

<header>
  <div>
    <div class="subtitle">Arquitectura de Base de Datos · v1.0</div>
    <h1>Modelo <span>Relacional</span></h1>
  </div>
  <div class="legend">
