</div><!-- /canvas -->

<script>
// Draw relationship lines between tables using element positions
const canvas = document.getElementById('canvas');
const svg = document.getElementById('svg-relations');

const rels = [
  // [from_id, to_id, color, marker]
  ['t-roles',     't-usuarios',   '#4fffb0', 'arrow-green'],
  ['t-usuarios',  't-tramites',   '#4fc3ff', 'arrow-blue'],
  ['t-tipos',     't-tramites',   '#4fc3ff', 'arrow-blue'],
  ['t-estados',   't-tramites',   '#4fc3ff', 'arrow-blue'],
  ['t-tramites',  't-fases',      '#c084fc', 'arrow-purple'],
  ['t-carpetas',  't-documentos', '#ffc84a', 'arrow-yellow'],
  ['t-usuarios',  't-documentos', '#ffc84a', 'arrow-yellow'],
  // self-ref fases
  ['t-fases',     't-fases',      '#c084fc', 'arrow-purple'],
];

function midRight(el) {
  const r = el.getBoundingClientRect();
  const cr = canvas.getBoundingClientRect();
  return { x: r.right - cr.left, y: r.top - cr.top + r.height / 2 };
}
function midLeft(el) {
  const r = el.getBoundingClientRect();
  const cr = canvas.getBoundingClientRect();
  return { x: r.left - cr.left, y: r.top - cr.top + r.height / 2 };
}
function midBottom(el) {
  const r = el.getBoundingClientRect();
  const cr = canvas.getBoundingClientRect();
  return { x: r.left - cr.left + r.width / 2, y: r.bottom - cr.top };
}
function midTop(el) {
  const r = el.getBoundingClientRect();
  const cr = canvas.getBoundingClientRect();
  return { x: r.left - cr.left + r.width / 2, y: r.top - cr.top };
}

function drawLines() {
  svg.querySelectorAll('path.dyn').forEach(p => p.remove());

  rels.forEach(([fid, tid, color, marker]) => {
    const from = document.getElementById(fid);
    const to   = document.getElementById(tid);
    if (!from || !to) return;

    let p, d;

    if (fid === tid) {
      // Self-referencing arc for fases_ruta
      const r = from.getBoundingClientRect();
      const cr = canvas.getBoundingClientRect();
      const x = r.right - cr.left;
      const y = r.bottom - cr.top - 30;
      d = `M ${x} ${y} C ${x+60} ${y+10}, ${x+60} ${y+50}, ${x} ${y+50}`;
    } else {
      const fr = from.getBoundingClientRect();
      const tr = to.getBoundingClientRect();
      const cr = canvas.getBoundingClientRect();

      // Determine connection direction
      const fx_r = fr.right - cr.left;
      const fx_l = fr.left - cr.left;
      const fy_m = fr.top - cr.top + fr.height/2;
      const tx_r = tr.right - cr.left;
      const tx_l = tr.left - cr.left;
      const ty_m = tr.top - cr.top + tr.height/2;

      let sx, sy, ex, ey;

      // If from is clearly left of to
      if (fx_r < tx_l + 20) {
        sx = fx_r; sy = fy_m;
        ex = tx_l; ey = ty_m;
      } else if (fx_l > tx_r - 20) {
        sx = fx_l; sy = fy_m;
        ex = tx_r; ey = ty_m;
      } else {
        // vertical
        const fy_b = fr.bottom - cr.top;
        const ty_t = tr.top - cr.top;
        sx = fr.left - cr.left + fr.width/2;
        sy = fy_b;
        ex = tr.left - cr.left + tr.width/2;
        ey = ty_t;
      }

      const mx = (sx + ex) / 2;
      d = `M ${sx} ${sy} C ${mx} ${sy}, ${mx} ${ey}, ${ex} ${ey}`;
    }

    p = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    p.setAttribute('d', d);
    p.setAttribute('class', 'rel-line dyn');
    p.setAttribute('stroke', color);
    p.setAttribute('marker-end', `url(#${marker})`);
    svg.appendChild(p);
  });
}

// Draw after layout settles
setTimeout(drawLines, 100);
window.addEventListener('resize', drawLines);
</script>

